# Database Configuration (FREE - Using H2 for development)
# H2 Database (embedded, no setup required)
# For production, uncomment PostgreSQL:
# POSTGRES_DB=syllabussync
# POSTGRES_USER=syllabussync
# POSTGRES_PASSWORD=syllabussync_password

# Google OAuth Configuration (FREE - Google provides free OAuth)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Configuration (FREE - No external service needed)
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# Application Configuration
SPRING_PROFILES_ACTIVE=development
NODE_ENV=development

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# File Upload Configuration (FREE - Local storage)
MAX_FILE_SIZE=10MB
UPLOAD_DIR=./uploads

# Email Configuration (FREE - Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Cache Configuration (FREE - Using simple cache instead of Redis)
# For production, you can use free Redis hosting:
# REDIS_HOST=your-free-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# Logging Configuration (FREE - Local file logging)
LOG_LEVEL=INFO
LOG_FILE=./logs/syllabussync.log
